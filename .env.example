# MongoDB
MONGODB_URI=
MONGODB_DB=calebareeveso

# Resend (https://resend.com) — used for newsletter welcome + post emails
RESEND_API_KEY=

# From address. Use onboarding@resend.dev until your domain is verified in Resend.
NEWSLETTER_FROM_EMAIL=
NEWSLETTER_FROM_NAME=Caleb Areeveso

# Public site origin (no trailing slash) — used to build email + unsubscribe links
NEXT_PUBLIC_SITE_URL=https://calebareeveso.com

# Local-only dev editor. Must be "true" AND NODE_ENV != production to enable.
DEV_EDITOR_ENABLED=false

# Optional: protects /api/newsletter/send-post (send via Bearer token / x-newsletter-secret)
NEWSLETTER_SEND_SECRET=
